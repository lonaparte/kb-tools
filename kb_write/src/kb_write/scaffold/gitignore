# kb-write init .gitignore
#
# This file is generated by `kb-write init`. Safe to edit; subsequent
# `kb-write init` runs won't overwrite it (it's a one-shot scaffold).

# Runtime state (sqlite index, write lock, audit log, citation cache).
# Derived data — rebuildable via `kb-mcp index` + `kb-citations fetch`.
# Not committed so multi-machine setups don't fight over it.
.kb-mcp/

# Per-user Claude Code permission overrides. settings.json IS committed
# (team-wide safe defaults); settings.local.json is personal.
.claude/settings.local.json

# Editor / OS cruft
.DS_Store
*.swp
*~
.idea/
.vscode/

# Python bytecode (rare in a KB but guarded anyway)
__pycache__/
*.pyc
